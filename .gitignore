# ===============================
# LARAVEL
# ===============================
/vendor
/node_modules
/public/storage
/storage/*.key
/storage/app/*
!/storage/app/public
/bootstrap/cache/*.php
.env
.env.*
!.env.example
!.env.deploy.example
.phpunit.result.cache
Homestead.json
Homestead.yaml

# ===============================
# LOG & DEBUG
# ===============================
storage/logs/*
npm-debug.log
yarn-error.log

# ===============================
# LARAVEL RUNTIME CACHE (should not be committed)
# ===============================
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/testing/*
storage/framework/views/*
!storage/framework/cache/.gitignore
!storage/framework/sessions/.gitignore
!storage/framework/testing/.gitignore
!storage/framework/views/.gitignore

# ===============================
# DOCKER
# ===============================
docker-compose.override.yml
.env.docker

# ===============================
# DEPLOY SECRETS (credentials + SSH keys)
# ===============================
.env.deploy
.deploy_keys/
!.deploy_keys/.gitkeep

# ===============================
# CLOUDFARE
# ===============================
/etc/cloudflared/*.json
/etc/cloudflared/*.pem
/etc/cloudflared/*.crt
/etc/cloudflared/*.key

# ===============================
# OS
# ===============================
.DS_Store
Thumbs.db
