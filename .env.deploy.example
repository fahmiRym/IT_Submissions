# ============================================================
# Deploy config — dipakai deploy-dev.ps1 & deploy-prod.ps1
# ============================================================
# 1. Copy file ini ke `.env.deploy` (gitignored)
# 2. Isi credential asli
# 3. Jalankan: .\deploy-dev.ps1  atau  .\deploy-prod.ps1
#
# Auth method: SSH KEY (public key auth) — TIDAK PAKAI PASSWORD.
# Kalau server belum punya public key kita, jalankan sekali:
#   ssh-copy-id -i .deploy_keys/deploy_key.pub root@192.168.11.199
# (butuh password sekali di prompt, setelah itu key auth aktif.)
# ============================================================

# --- DEV SERVER ---
DEV_HOST=192.168.11.199
DEV_USER=root
DEV_PROJECT_DIR=/root/it_submissions
DEV_SSH_KEY=.deploy_keys/deploy_key

# --- PROD SERVER ---
PROD_HOST=192.168.11.200
PROD_USER=root
PROD_PROJECT_DIR=/var/www
PROD_SSH_KEY=.deploy_keys/deploy_key

# --- DOCKER (opsional — kosongkan kalau tidak pakai Docker) ---
# Nama service compose yg mau di-restart (comma-separated).
# Kosong = restart SEMUA service di docker-compose.yml
DOCKER_COMPOSE_FILE=docker-compose.yml
DOCKER_SERVICES=

# --- FALLBACK PASSWORD (hanya kalau SSH key belum di-setup) ---
# Kosongkan setelah SSH key jalan. Kalau di-isi, script pakai password mode.
DEV_FALLBACK_PASSWORD=
PROD_FALLBACK_PASSWORD=
